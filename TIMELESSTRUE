local Home = Window:MakeTab({
    Name = "Home",
    Icon = "rbxassetid://4483345998"
})

Home:AddLabel("By timelesstrue")

Home:AddButton({
    Name = "Delete Character Box",
    Callback = function()
        for _,v in ipairs(workspace:GetDescendants()) do
            if string.find(v.Name,"Cost") then
